---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools } from '../data/tools';
---

<Base title="molpath.tools — Molecular Pathology Tools">
  <main class="mp-layout">
    <!-- Hero -->
    <section class="hero mp-animate-in">
      <div class="hero-title">
        <img src="/favicon.svg" alt="molpath.tools" class="hero-icon" />
        <h1><span class="accent">molpath</span>.tools</h1>
      </div>
      <p class="hero-lead">
        Open-source web tools for molecular pathology, clinical genomics, and
        diagnostic decision support.
      </p>
    </section>

    <!-- Tools -->
    <section class="tools-section">
      <h2 class="mp-section-title">Tools</h2>
      <div class="tools-grid">
        {tools.map((tool, i) => <ToolCard tool={tool} index={i} />)}
      </div>
    </section>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-links">
        <a href="https://viktorljungstrom.com">Viktor Ljungström</a>
        <a href="https://github.com/viktorlj">GitHub</a>
      </div>
      <p>
        Built in Uppsala, Sweden. All tools are for research and clinical
        decision support — not standalone diagnostics.
      </p>
    </footer>
  </main>
</Base>
